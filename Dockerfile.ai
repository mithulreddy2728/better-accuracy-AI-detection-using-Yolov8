FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for OpenCV (headless) and other libs
RUN apt-get update && apt-get install -y \
    gcc \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY ai_engine/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy AI engine code into /app/ai_engine so imports resolve correctly
COPY ai_engine/ ./ai_engine/

# Run the AI engine via main.py entrypoint
CMD ["python", "ai_engine/main.py"]
