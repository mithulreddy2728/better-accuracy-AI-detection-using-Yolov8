# ── Backend ─────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="294dbfc7d20df24a9be7206b4359aff2c526322ab1089abf78ec1dd1370123c6"

# SQLite database path (relative to /app inside the backend container)
DATABASE_URL=sqlite:///./nozzle_detection.db

# CORS: comma-separated list of allowed frontend origins.
# Local dev:   http://localhost:3000
# Docker:      http://localhost
# Production:  https://yourdomain.com
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ── AI Engine ────────────────────────────────────────────────────────────────
# URL of the backend as seen from inside the Docker network.
# Do NOT change this unless you rename the backend service.
AI_API_BASE_URL=http://backend:8000

# How often (seconds) the AI engine polls for tasks.
DETECTION_INTERVAL=5

# ── Backend Server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
